FROM eclipse-temurin:17-jdk-jammy

WORKDIR /app

# Copy the built JAR
COPY target/*.jar app.jar

# Expose the port
EXPOSE 8082

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD curl -f http://localhost:8082/actuator/health || exit 1

# Run the application
ENTRYPOINT ["java", "-jar", "app.jar"]
